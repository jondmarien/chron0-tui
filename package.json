{
  "name": "chron0-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SSH-accessible TUI portfolio for Jon Marien (chrono). Render Ink via ssh2.",
  "scripts": {
    "gen-assets": "bun scripts/gen-assets.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "figlet": "^1.7.0",
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.6",
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/ssh2": "^1.15.0",
    "asciify-image": "^0.1.6",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  },
  "engines": {
    "bun": ">=1.1"
  }
}
